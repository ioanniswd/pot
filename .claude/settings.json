{
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(task --list *)",
      "Bash(task lint *)",
      "Bash(task format *)",
      "Bash(task check *)",
      "Bash(task typecheck *)",
      "Bash(task test *)",
      "Bash(task build *)",
      "Bash(task ci *)",
      "Bash(task compile *)",
      "Bash(bun test *)",
      "Bash(gh auth status)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$CLAUDE_TOOL_INPUT_FILE_PATH\" in *.ts) bunx biome format --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null && bunx tsc --noEmit 2>&1 | head -20 ;; esac",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
