{
  "name": "pot",
  "version": "3.0.1",
  "description": "CLI for GitHub PR overview and team workload distribution",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pot": "build/index.js"
  },
  "files": [
    "build/**/*.js",
    "build/**/*.d.ts",
    "README.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "build": "tsc",
    "start": "bun run build/index.js",
    "format": "bunx biome format --write .",
    "format:check": "bunx biome format .",
    "lint": "bunx biome lint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit --timeout 10000",
    "test:e2e": "bun test tests/e2e --timeout 30000",
    "prepare": "lefthook install || true"
  },
  "keywords": [
    "cli",
    "github",
    "pull-requests",
    "pr-overview",
    "code-review"
  ],
  "author": "Giannis Poulis <ioanniswd@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ioanniswd/pot.git"
  },
  "homepage": "https://github.com/ioanniswd/pot#readme",
  "bugs": {
    "url": "https://github.com/ioanniswd/pot/issues"
  },
  "dependencies": {
    "clerc": "1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.5",
    "typescript": "^5.9.3"
  }
}
